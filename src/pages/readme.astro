---
import Layout from '../layouts/Layout.astro';
import resumeData from '../../public/resume.json';

const { basics, work, education, certificates } = resumeData as any;

// Merge arrays into a timeline
const timeline = [
	...(work || []).map((item: any) => ({ ...item, type: 'work', date: new Date(item.startDate) })),
	...(education || []).map((item: any) => ({ ...item, type: 'education', date: new Date(item.startDate) })),
	...(certificates || []).map((item: any) => ({ ...item, type: 'certificate', date: new Date(item.date) }))
].sort((a: any, b: any) => b.date.getTime() - a.date.getTime());

// Define specific tech stack icons mapped to Simple Icons CDN
const techStack = [
	{ name: "TypeScript", icon: "https://cdn.simpleicons.org/typescript/3178C6" },
	{ name: "JavaScript", icon: "https://cdn.simpleicons.org/javascript/F7DF1E" },
	{ name: "Kubernetes", icon: "https://cdn.simpleicons.org/kubernetes/326CE5" },
	{ name: "Python", icon: "https://cdn.simpleicons.org/python/3776AB" },
	{ name: "React", icon: "https://cdn.simpleicons.org/react/61DAFB" },
	{ name: "Node.js", icon: "https://cdn.simpleicons.org/nodedotjs/5FA04E" },
	{ name: "Spring Boot", icon: "https://cdn.simpleicons.org/springboot/6DB33F" },
	{ name: "AWS", icon: "https://cdn.simpleicons.org/amazonaws/FF9900" },
	{ name: "Terraform", icon: "https://cdn.simpleicons.org/terraform/844FBA" },
	{ name: "Docker", icon: "https://cdn.simpleicons.org/docker/2496ED" },
	{ name: "PostgreSQL", icon: "https://cdn.simpleicons.org/postgresql/4169E1" },
	{ name: "MongoDB", icon: "https://cdn.simpleicons.org/mongodb/47A248" },
	{ name: "Elasticsearch", icon: "https://cdn.simpleicons.org/elasticsearch/005571" },
	{ name: "Kafka", icon: "https://cdn.simpleicons.org/apachekafka/white" },
	{ name: "Linux", icon: "https://cdn.simpleicons.org/linux/white" },
];

const timelineTheme = {
	work: {
		border: 'border-tokyo-magenta',
		text: 'text-tokyo-magenta',
		hoverText: 'group-hover:text-tokyo-magenta',
		bgBadge: 'bg-tokyo-magenta/10',
		shadow: 'shadow-[0_0_10px_rgba(247,118,142,0.5)]',
		cardHoverBorder: 'hover:border-tokyo-magenta',
		cardHoverShadow: 'hover:shadow-[0_0_20px_rgba(247,118,142,0.1)]',
		label: 'Work'
	},
	education: {
		border: 'border-tokyo-blue',
		text: 'text-tokyo-blue',
		hoverText: 'group-hover:text-tokyo-blue',
		bgBadge: 'bg-tokyo-blue/10',
		shadow: 'shadow-[0_0_10px_rgba(122,162,247,0.5)]',
		cardHoverBorder: 'hover:border-tokyo-blue',
		cardHoverShadow: 'hover:shadow-[0_0_20px_rgba(122,162,247,0.1)]',
		label: 'Education'
	},
	certificate: {
		border: 'border-tokyo-green',
		text: 'text-tokyo-green',
		hoverText: 'group-hover:text-tokyo-green',
		bgBadge: 'bg-tokyo-green/10',
		shadow: 'shadow-[0_0_10px_rgba(158,206,106,0.5)]',
		cardHoverBorder: 'hover:border-tokyo-green',
		cardHoverShadow: 'hover:shadow-[0_0_20px_rgba(158,206,106,0.1)]',
		label: 'Certificate'
	}
};
---

<Layout title="Developer Profile | Younes El Alami">
	<article class="max-w-3xl mx-auto px-4 md:px-0 py-10 md:py-20 animate-[fade-in_0.8s_ease-out]">
		
		<!-- Hero Section -->
		<header class="mb-16 border-b border-tokyo-comment/20 pb-10">
			<div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
				<div>
					<h1 class="text-4xl md:text-5xl font-bold lights-text pb-2 mb-2">
						{basics.name}
					</h1>
					<h2 class="text-xl md:text-2xl text-tokyo-cyan font-mono mb-4 flex items-center">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"></path><path d="m14.5 4-5 16"></path></svg>
						{basics.label}
					</h2>
					<div class="flex items-center space-x-4 text-tokyo-comment font-mono text-sm">
						<span class="flex items-center">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2 text-tokyo-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
							{basics.location.city}, {basics.location.countryCode}
						</span>
						<a href={`mailto:${basics.email}`} class="flex items-center hover:text-tokyo-yellow transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2 text-tokyo-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
							{basics.email}
						</a>
						<a href={basics.profiles[0].url} target="_blank" rel="noopener noreferrer" class="flex items-center hover:text-white transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
							GitHub
						</a>
					</div>
				</div>
				
				<!-- Recruiter CTA Component -->
				<a 
					href="/younes.el-alami.cv.docx.pdf" 
					download
					class="shrink-0 flex items-center justify-center px-6 py-3 bg-tokyo-blue/10 border border-tokyo-blue/50 text-tokyo-blue hover:bg-tokyo-blue hover:text-tokyo-bg-alt rounded-md font-bold transition-all duration-300 shadow-[0_0_15px_rgba(122,162,247,0.15)] hover:shadow-[0_0_25px_rgba(122,162,247,0.4)] group whitespace-nowrap"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-3 group-hover:-translate-y-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
					Download PDF
				</a>
			</div>
			
			<p class="mt-8 text-tokyo-fg/90 leading-relaxed text-lg prose-tokyo">
				{basics.summary}
			</p>
		</header>

		<!-- Core Architecture Grid -->
		<section class="mb-16">
			<h2 class="text-2xl md:text-3xl font-bold mb-8 text-tokyo-purple border-b border-tokyo-purple/30 pb-2 flex items-center">
				<svg xmlns="http://www.w3.org/2000/svg" class="mr-3 w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"></path><path d="m14.5 4-5 16"></path></svg>
				/sys/core/stack
			</h2>
			
			<div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-7 gap-4">
				{techStack.map(tech => (
					<div class="flex flex-col items-center justify-center p-4 glass-card rounded-lg hover:border-tokyo-purple hover:bg-tokyo-purple/5 transition-all group shadow-sm hover:shadow-[0_0_15px_rgba(187,154,247,0.1)]">
						<img 
							src={tech.icon} 
							alt={tech.name} 
							width="40"
							height="40"
							class="w-10 h-10 group-hover:scale-110 transition-transform duration-300 drop-shadow-md" 
							loading="lazy"
						/>
						<span class="mt-3 text-[11px] font-mono font-bold text-tokyo-cyan group-hover:text-white transition-colors text-center">
							{tech.name}
						</span>
					</div>
				))}
			</div>
		</section>

		<!-- Experience Timeline -->
		<section>
			<h2 class="text-2xl md:text-3xl font-bold mb-8 text-tokyo-magenta border-b border-tokyo-magenta/30 pb-2 flex items-center">
				<svg xmlns="http://www.w3.org/2000/svg" class="mr-3 w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"></path><circle cx="12" cy="12" r="10"></circle></svg>
				/var/log/timeline
			</h2>
			
			<div class="space-y-8 relative before:content-[''] before:absolute before:inset-0 before:ml-6 md:before:ml-8 before:-translate-x-px before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-tokyo-comment/30 before:to-transparent">
				{timeline.map((item: any) => {
					// Dynamic theme mapping per item type
					const type = item.type as "work" | "education" | "certificate";
					const theme = timelineTheme[type];
					const year = item.date.getFullYear();
					
					return (
						<div class="relative flex items-start group is-active">
							<!-- Timeline Badge Box (Year) instead of a simple dot -->
							<div class={`flex items-center text-[10px] font-bold justify-center w-12 py-1.5 rounded border ${theme.border} bg-tokyo-bg shrink-0 absolute left-0 md:left-2 top-6 ${theme.shadow} group-hover:scale-110 transition-transform duration-300 z-10 ${theme.text}`}>
								{year}
							</div>
							
							<!-- Content Box -->
							<div class={`ml-16 md:ml-20 w-[calc(100%-4rem)] md:w-[calc(100%-5rem)] glass-card p-5 md:p-6 rounded-lg ${theme.cardHoverBorder} ${theme.cardHoverShadow} transition-all duration-300`}>
								<div class="flex flex-col mb-3">
									<h3 class={`text-xl md:text-2xl font-bold text-tokyo-fg ${theme.hoverText} transition-colors leading-tight`}>
										{type === 'work' ? item.position : type === 'education' ? item.area : item.name}
									</h3>
									<span class="text-tokyo-cyan font-mono text-sm mt-2">@ {type === 'work' ? item.name : type === 'education' ? item.institution : item.issuer}</span>
								</div>
								
								<div class="text-[11px] font-mono text-tokyo-comment mb-4 flex flex-wrap items-center gap-2">
									<span class={`px-2 py-0.5 rounded-sm ${theme.bgBadge} ${theme.text} border border-current opacity-80 uppercase tracking-widest`}>
										{theme.label}
									</span>
									{type === 'work' && item.location && <span>• {item.location}</span>}
									{type === 'education' && item.studyType && <span>• {item.studyType}</span>}
								</div>
								
								{item.summary && (
									<p class="text-sm text-tokyo-fg/70 leading-relaxed mb-4">
										{item.summary}
									</p>
								)}
							</div>
						</div>
					);
				})}
				
				<!-- Start block -->
				<div class="relative flex justify-start pt-8 pb-4 z-10 space-x-0">
					<div class="ml-0 md:ml-1 bg-tokyo-bg-alt border border-tokyo-comment/30 px-6 py-2 rounded-full text-tokyo-comment text-[10px] font-mono tracking-widest uppercase">
						system boot
					</div>
				</div>
			</div>
		</section>
		
		<div class="mt-20 text-center w-full">
			<a href="/" class="inline-flex items-center text-tokyo-comment hover:text-white transition-colors font-mono tracking-widest uppercase text-sm">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
				cd ~
			</a>
		</div>

	</article>
</Layout>
